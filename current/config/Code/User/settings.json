{
	"launch": {
		"configurations": [],
		"compounds": []
	},
	"workbench.editor.pinnedTabsOnSeparateRow": true,
	"workbench.editor.wrapTabs": true,
	"workbench.editor.highlightModifiedTabs": true,
	"workbench.activityBar.location": "top",
	"window.menuBarVisibility": "compact",
	"window.commandCenter": false,
	"window.zoomLevel": 0.2,
	"editor.inlayHints.enabled": "on",
	"editor.fontFamily": "'Cascadia Code', 'Droid Sans Mono', 'monospace', monospace",
	"editor.fontSize": 13,
	"editor.renderWhitespace": "all",
	"editor.minimap.autohide": "mouseover",
	"editor.formatOnType": true,
	"editor.inlayHints.fontSize": 10,
	"editor.lineNumbers": "on",
	"editor.renderLineHighlight": "all",
	"git.blame.editorDecoration.enabled": true,
	"git-graph.dialog.rebase.launchInteractiveRebase": true,
	"git-graph.dialog.fetchIntoLocalBranch.forceFetch": true,
	"github.copilot.nextEditSuggestions.enabled": false,
	"github.copilot.nextEditSuggestions.allowWhitespaceOnlyChanges": false,
	"github.copilot.nextEditSuggestions.fixes": false,
	"github.copilot.renameSuggestions.triggerAutomatically": false,
	"diffEditor.ignoreTrimWhitespace": false,
	"debug.breakpointsView.presentation": "tree",
	"scm.repositories.explorer": true,
	"scm.repositories.selectionMode": "single",
	"scm.diffDecorations": "all",
	"scm.diffDecorationsGutterWidth": 5,
	"scm.diffDecorationsGutterVisibility": "always",
	"scm.defaultViewMode": "tree",
	"hediet.vscode-drawio.resizeImages": null,
	"chat.viewSessions.orientation": "stacked",
	"hediet.vscode-drawio.theme": "kennedy",
	"hediet.vscode-drawio.appearance": "dark",
	"extensions.autoUpdate": false,
	"extensions.experimental.affinity": {
		"asvetliakov.vscode-neovim": 1
	},
	"claudeCode.preferredLocation": "panel",
	"claudeCode.useTerminal": true,
	"zig.zls.enabled": "on",
	"dotnet.automaticallyCreateSolutionInWorkspace": false,
	"dotnet.inlayHints.enableInlayHintsForObjectCreationParameters": true,
	"dotnet.inlayHints.enableInlayHintsForOtherParameters": true,
	"dotnet.inlayHints.enableInlayHintsForParameters": true,
	"dotnet.inlayHints.enableInlayHintsForLiteralParameters": true,
	"js.inlayHints.functionLikeReturnTypes.enabled": true,
	"js.inlayHints.parameterNames.enabled": "all",
	"js.inlayHints.parameterTypes.enabled": true,
	"js.inlayHints.propertyDeclarationTypes.enabled": true,
	"js.inlayHints.variableTypes.enabled": true,
	"ts.inlayHints.enumMemberValues.enabled": true,
	"ts.inlayHints.functionLikeReturnTypes.enabled": true,
	"ts.inlayHints.parameterTypes.enabled": true,
	"ts.inlayHints.propertyDeclarationTypes.enabled": true,
	"ts.inlayHints.variableTypes.enabled": true,
	"[typescript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[json]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
